# Server Configuration
PORT=3000

# PostgreSQL Connection String (Render/local)
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/academic_tasks

# JWT Authentication
# Generate a strong, random secret key for production
JWT_SECRET=super_secret_production_key_123!

# Cloudinary (Screenshot Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Production Frontend URL for CORS (Optional)
FRONTEND_URL=https://your-frontend.onrender.com
